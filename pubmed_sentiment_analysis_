    "Entrez.email = \"mariaquintana0220@gmail.com\"\n",
    "\n",
    "def fetch_abstracts(query, start_year, end_year, max_results=200):\n",
    "    records = []\n",
    "    for year in range(start_year, end_year + 1):\n",
    "        search = Entrez.esearch(\n",
    "            db=\"pubmed\",\n",
    "            term=f\"{query} AND {year}[pdat]\",\n",
    "            retmax=max_results\n",
    "        )\n",
    "        result = Entrez.read(search)\n",
    "        ids = result[\"IdList\"]\n",
    "        \n",
    "        if not ids:\n",
    "            continue\n",
    "            \n",
    "        fetch = Entrez.efetch(\n",
    "            db=\"pubmed\",\n",
    "            id=ids,\n",
    "            rettype=\"abstract\",\n",
    "            retmode=\"xml\"\n",
    "        )\n",
    "        data = Entrez.read(fetch)\n",
    "        \n",
    "        for article in data[\"PubmedArticle\"]:\n",
    "            try:\n",
    "                abstract = article[\"MedlineCitation\"][\"Article\"][\"Abstract\"][\"AbstractText\"][0]\n",
    "                records.append({\n",
    "                    \"year\": year,\n",
    "                    \"abstract\": str(abstract)\n",
    "                })\n",
    "            except:\n",
    "                continue\n",
    "                \n",
    "    return pd.DataFrame(records)\n",
    "\n",
    "df = fetch_abstracts(\"depression psychology\", 2000, 2024, max_results=50)\n",
    "print(f\"Pulled {len(df)} abstracts\")\n",
    "df.head()"
   ]
